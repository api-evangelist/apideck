    },
    "bsb_number": {
      "$ref": "#/components/schemas/BSBNumber"
    },
    "branch_identifier": {
      "$ref": "#/components/schemas/BranchIdentifier"
    },
    "bank_code": {
      "$ref": "#/components/schemas/BankCode"
