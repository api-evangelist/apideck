{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/OutstandingBalanceByCustomer",
  "title": "Outstanding Balance",
  "type": "object",
  "x-apideck-schema-id": "OutstandingBalanceByCustomer",
