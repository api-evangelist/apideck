{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/LinkedInvoiceItem",
  "title": "LinkedInvoiceItem",
  "type": "object",
  "x-apideck-schema-id": "LinkedInvoiceItem",
  "x-apideck-weights": {
    "id": "medium",
    "code": "medium",
    "name": "medium"
  },
  "properties": {
    "id": {
      "type": "string",
      "title": "Item ID",
      "description": "ID of the linked item. A reference to the [invoice item](https://developers.apideck.com/apis/accounting/reference#tag/Invoice-Items) that was used to create this line item",
      "example": "12344",
      "nullable": true
    },
    "code": {
      "type": "string",
      "title": "Item code",
      "description": "User defined item code",
      "example": "120-C",
      "nullable": true
    },
    "name": {
      "type": "string",
      "title": "Item name",
      "description": "User defined item name",
      "example": "Model Y",
      "nullable": true
    }
  }
}