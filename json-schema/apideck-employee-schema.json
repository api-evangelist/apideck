{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Employee",
  "title": "Employee",
  "type": "object",
  "x-apideck-schema-id": "Employee",
  "x-apideck-weights": {
    "id": "medium",
    "downstream_id": "medium",
    "first_name": "critical",
    "last_name": "critical",
    "middle_name": "medium",
    "display_name": "edge-case",
