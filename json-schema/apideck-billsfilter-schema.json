      "example": "2020-09-30T07:43:32.000Z"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "description": "Filter by bill status",
      "x-apideck-enum-id": "bills.status",
      "enum": [
        "paid",
        "unpaid",
        "partially_paid"
      ],
      "example": "paid"
    }
  },
  "additionalProperties": false
}